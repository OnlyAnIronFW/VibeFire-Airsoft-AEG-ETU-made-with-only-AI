# ============================================================
# VibeFire 项目 .gitignore
# ============================================================

# PlatformIO build output
.pio/
.pioenvs/
.piolibdeps/

# PlatformIO IDE
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# Build directories (AutoTrigger)
build*/
cmake-build-*/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Object files
*.o
*.obj
*.out

# Binary artifacts
*.rknn
*.bin
*.elf
*.hex
*.eep

# Library files
*.so
*.a
*.dll
*.dylib

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# OS
.DS_Store
Thumbs.db

# Session logs
logs/
.omo/run-continuation/

# Screenshots / QA artifacts
*.png
*.jpg

# Claude / AI config
.claude/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Dependencies
node_modules/

# Claude / AI session data
.claude/settings.local.json
*.playwright-mcp/

# Sensitive
.env
*.log
